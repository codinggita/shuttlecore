# ShuttleCore Backend - Environment Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ==========================================
# Server Configuration
# ==========================================
# Port the Express server listens on
# Default: 5000
PORT=5000

# Node environment mode (development | production | test)
# Default: development
NODE_ENV=development

# ==========================================
# Database Configuration
# ==========================================
# MongoDB connection URI (default port: 27017)
# Format: mongodb://[user:pass@]host:port/database
# Default: mongodb://localhost:27017/shuttlecore
MONGODB_URI=mongodb://localhost:27017/shuttlecore

# ==========================================
# JWT Authentication
# ==========================================
# Secret key for signing JWT tokens (generate a strong random string)
# IMPORTANT: Change this in production! Minimum 32 characters recommended.
# Example: openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Token expiration time (e.g. 1d, 7d, 30d, 1h)
# Default: 7d
JWT_EXPIRE=7d

# ==========================================
# Socket.io / WebSocket
# ==========================================
# CORS origin for WebSocket connections (frontend dev server URL)
# Default: http://localhost:5173
SOCKET_CORS_ORIGIN=http://localhost:5173
