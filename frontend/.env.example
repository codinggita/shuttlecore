# ShuttleCore Frontend - Environment Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ─── Backend API URL ─────────────────────────────────────────────────────────
# Must be the FULL URL including /api path.
#
# Local dev:   http://localhost:5000/api
# Production:  https://shuttle-core.onrender.com/api
#
# TO SET IN NETLIFY DASHBOARD:
#   Site Configuration → Environment Variables → Add a variable
#   Key:   VITE_API_BASE_URL
#   Value: https://shuttle-core.onrender.com/api
#
VITE_API_BASE_URL=http://localhost:5000/api

# ─── Socket.io Server URL ────────────────────────────────────────────────────
# Root URL of the backend — NO /api suffix.
#
# Local dev:   http://localhost:5000
# Production:  https://shuttle-core.onrender.com
#
# TO SET IN NETLIFY DASHBOARD:
#   Key:   VITE_SOCKET_URL
#   Value: https://shuttle-core.onrender.com
#
VITE_SOCKET_URL=http://localhost:5000
