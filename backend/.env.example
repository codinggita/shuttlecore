# ShuttleCore Backend - Environment Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ==========================================
# Server Configuration
# ==========================================
# Port the Express server listens on
# Default: 5000 (Render sets this automatically — do not override on Render)
PORT=5000

# Node environment mode (development | production | test)
NODE_ENV=development

# ==========================================
# Database Configuration
# ==========================================
# MongoDB connection URI
# Local:      mongodb://localhost:27017/shuttlecore
# Production: your MongoDB Atlas connection string
# Format: mongodb+srv://user:pass@cluster.mongodb.net/shuttlecore?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/shuttlecore

# ==========================================
# JWT Authentication
# ==========================================
# Secret key for signing JWT tokens (generate a strong random string)
# IMPORTANT: Change this in production! Minimum 32 characters recommended.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Token expiration time (e.g. 1d, 7d, 30d, 1h)
JWT_EXPIRE=7d

# ==========================================
# CORS / Frontend Origin
# ==========================================
# Comma-separated list of allowed frontend origins.
# The backend CORS and Socket.io both read this variable.
#
# Local:      http://localhost:5173
# Production: https://shuttle-core1.netlify.app
#
# TO SET IN RENDER DASHBOARD:
#   Dashboard → Your Service → Environment → Add Environment Variable
#   Key:   FRONTEND_URL
#   Value: https://shuttle-core1.netlify.app
#
# Multiple origins (comma-separated, no spaces):
#   Value: https://shuttle-core1.netlify.app,https://shuttle-core.netlify.app
FRONTEND_URL=http://localhost:5173

# ==========================================
# Self-reference (optional)
# ==========================================
# Useful for internal service calls, seeding scripts, or health-check crons.
# Local:      http://localhost:5000
# Production: https://shuttle-core.onrender.com
BACKEND_URL=http://localhost:5000
